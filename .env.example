# Optional runtime overrides. Copy this file to .env if you want local overrides.

# Project/data directories
BADMINTON_PROJECT_ROOT=
BADMINTON_DATA_DIR=
BADMINTON_MODEL_DIR=

# Model assets
BADMINTON_YOLO_MODEL=models/yolov8s.pt
BADMINTON_POSE_MODEL=models/pose_landmarker.task
BADMINTON_TRACKNET_WEIGHTS=models/tracknet_weights.pt

# Generated files
BADMINTON_BALL_SPEED_CSV=data/logs/ball_speeds.csv
BADMINTON_TRACKER_CONFIG=data/logs/bytetrack.generated.yaml

# Force a specific ffmpeg H.264 encoder if needed: libx264 or h264_nvenc.
BADMINTON_FFMPEG_CODEC=
